datasource db {
  provider = "postgresql"
}

enum RiskLevel {
  LOW      @map("Low")
  MEDIUM   @map("Medium")
  HIGH     @map("High")
  CRITICAL @map("Critical")

  @@map("risk_level")
}

enum HouseStatus {
  NOT_CHECKED      @map("Not Checked")
  SAFE             @map("Safe")
  NEEDS_ASSISTANCE @map("Needs Assistance")
  NEEDS_RESCUE     @map("Needs Rescue")
  EVACUATED        @map("Evacuated")

  @@map("house_status")
}

enum WaterLevel {
  NONE    @map("None")
  ANKLE   @map("Ankle")
  KNEE    @map("Knee")
  WAIST   @map("Waist")
  CHEST   @map("Chest")
  ROOF    @map("Roof")
  UNKNOWN @map("Unknown")

  @@map("water_level")
}

enum Sex {
  MALE              @map("Male")
  FEMALE            @map("Female")
  OTHER             @map("Other")
  PREFER_NOT_TO_SAY @map("Prefer Not To Say")

  @@map("sex")
}

enum ResidentStatus {
  INSIDE_HOUSE           @map("Inside House")
  EVACUATED              @map("Evacuated")
  MISSING_OR_UNCONFIRMED @map("Missing / Unconfirmed")
  NEEDS_RESCUE           @map("Needs Rescue")
  SAFE                   @map("Safe")

  @@map("resident_status")
}

enum ContactEntityType {
  LGU               @map("LGU")
  BARANGAY          @map("Barangay")
  AREA              @map("Area")
  HOUSE             @map("House")
  FAMILY            @map("Family")
  EVACUATION_CENTER @map("Evacuation Center")

  @@map("contact_entity_type")
}

enum ContactRole {
  LGU_ADMIN                @map("LGU Admin")
  MDRRMO_OFFICER           @map("MDRRMO Officer")
  BARANGAY_CAPTAIN         @map("Barangay Captain")
  BARANGAY_SECRETARY       @map("Barangay Secretary")
  RESPONDER                @map("Responder")
  PUROK_LEADER             @map("Purok Leader")
  HOUSEHOLD_REPRESENTATIVE @map("Household Representative")
  FAMILY_HEAD              @map("Family Head")
  RELATIVE                 @map("Relative")
  VOLUNTEER                @map("Volunteer")

  @@map("contact_role")
}

enum EvacuationCenterType {
  SCHOOL           @map("School")
  COVERED_COURT    @map("Covered Court")
  GYMNASIUM        @map("Gymnasium")
  BARANGAY_HALL    @map("Barangay Hall")
  CHURCH           @map("Church")
  COMMUNITY_CENTER @map("Community Center")
  OTHER            @map("Other")

  @@map("evacuation_center_type")
}

enum EvacuationCenterStatus {
  OPEN          @map("Open")
  NEAR_CAPACITY @map("Near Capacity")
  FULL          @map("Full")
  CLOSED        @map("Closed")
  UNAVAILABLE   @map("Unavailable")

  @@map("evacuation_center_status")
}

enum EvacuationAssignmentStatus {
  ASSIGNED               @map("Assigned")
  CHECKED_IN             @map("Checked In")
  TRANSFERRED            @map("Transferred")
  LEFT                   @map("Left")
  MISSING_OR_UNCONFIRMED @map("Missing / Unconfirmed")

  @@map("evacuation_assignment_status")
}

enum RescuePingStatus {
  NEW          @map("New")
  ACKNOWLEDGED @map("Acknowledged")
  RESPONDING   @map("Responding")
  RESOLVED     @map("Resolved")

  @@map("rescue_ping_status")
}

model Lgu {
  id                   String             @id @default(dbgenerated("concat('lgu_', replace((gen_random_uuid())::text, '-'::text, ''::text))"))
  name                 String
  province             String
  city_or_municipality String
  created_at           DateTime           @default(now()) @db.Timestamptz(6)
  updated_at           DateTime           @default(now()) @updatedAt @db.Timestamptz(6)
  barangays            Barangay[]
  evacuation_centers   EvacuationCenter[]

  @@map("lgus")
}

model Barangay {
  id                 String             @id @default(dbgenerated("concat('brgy_', replace((gen_random_uuid())::text, '-'::text, ''::text))"))
  lgu_id             String
  name               String
  area_name          String?
  risk_level         RiskLevel
  created_at         DateTime           @default(now()) @db.Timestamptz(6)
  updated_at         DateTime           @default(now()) @updatedAt @db.Timestamptz(6)
  lgu                Lgu                @relation(fields: [lgu_id], references: [id], onDelete: Cascade)
  houses             House[]
  evacuation_centers EvacuationCenter[]

  @@index([lgu_id])
  @@map("barangays")
}

model House {
  id              String                       @id @default(dbgenerated("concat('house_', replace((gen_random_uuid())::text, '-'::text, ''::text))"))
  barangay_id     String
  address         String
  landmark        String?
  latitude        Decimal?                     @db.Decimal(9, 6)
  longitude       Decimal?                     @db.Decimal(9, 6)
  current_status  HouseStatus                  @default(NOT_CHECKED)
  water_level     WaterLevel                   @default(UNKNOWN)
  last_checked_at DateTime?                    @db.Timestamptz(6)
  last_checked_by String?
  created_at      DateTime                     @default(now()) @db.Timestamptz(6)
  updated_at      DateTime                     @default(now()) @updatedAt @db.Timestamptz(6)
  barangay        Barangay                     @relation(fields: [barangay_id], references: [id], onDelete: Cascade)
  families        Family[]
  assignments     EvacuationCenterAssignment[]

  @@index([barangay_id])
  @@index([current_status])
  @@index([water_level])
  @@map("houses")
}

model Family {
  id                            String                       @id @default(dbgenerated("concat('family_', replace((gen_random_uuid())::text, '-'::text, ''::text))"))
  house_id                      String
  family_code                   String                       @unique @default(dbgenerated("concat('FAM-', upper(substr(replace((gen_random_uuid())::text, '-'::text, ''::text), 1, 6)))"))
  pin_code                      String                       @default("0000") @db.VarChar(4)
  family_name                   String
  head_of_family                String
  head_of_family_phone_number   String?
  total_members                 Int                          @default(0)
  current_inside_count          Int                          @default(0)
  evacuated_count               Int                          @default(0)
  missing_or_unconfirmed_count  Int                          @default(0)
  needs_assistance              Boolean                      @default(false)
  notes                         String?
  created_at                    DateTime                     @default(now()) @db.Timestamptz(6)
  updated_at                    DateTime                     @default(now()) @updatedAt @db.Timestamptz(6)
  house                         House                        @relation(fields: [house_id], references: [id], onDelete: Cascade)
  residents                     Resident[]
  evacuation_center_assignments EvacuationCenterAssignment[]

  @@index([house_id])
  @@index([needs_assistance])
  @@map("families")
}

model Resident {
  id             String         @id @default(dbgenerated("concat('resident_', replace((gen_random_uuid())::text, '-'::text, ''::text))"))
  family_id      String
  first_name     String
  last_name      String
  phone_number   String?
  age            Int?
  sex            Sex
  is_senior      Boolean        @default(false)
  is_child       Boolean        @default(false)
  is_pwd         Boolean        @default(false)
  is_pregnant    Boolean        @default(false)
  current_status ResidentStatus @default(INSIDE_HOUSE)
  created_at     DateTime       @default(now()) @db.Timestamptz(6)
  updated_at     DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  family         Family         @relation(fields: [family_id], references: [id], onDelete: Cascade)

  @@index([family_id])
  @@index([current_status])
  @@index([is_senior])
  @@index([is_child])
  @@index([is_pwd])
  @@index([is_pregnant])
  @@map("residents")
}

model ContactPerson {
  id                       String            @id @default(dbgenerated("concat('cp_', replace((gen_random_uuid())::text, '-'::text, ''::text))"))
  entity_type              ContactEntityType
  entity_id                String
  full_name                String
  role                     ContactRole
  contact_number           String
  alternate_contact_number String?
  email                    String?
  is_primary               Boolean           @default(false)
  notes                    String?
  created_at               DateTime          @default(now()) @db.Timestamptz(6)
  updated_at               DateTime          @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([entity_type, entity_id])
  @@index([is_primary])
  @@map("contact_persons")
}

model EvacuationCenter {
  id                  String                       @id @default(dbgenerated("concat('evac_', replace((gen_random_uuid())::text, '-'::text, ''::text))"))
  lgu_id              String
  barangay_id         String?
  name                String
  type                EvacuationCenterType         @default(OTHER)
  address             String
  landmark            String?
  latitude            Decimal?                     @db.Decimal(9, 6)
  longitude           Decimal?                     @db.Decimal(9, 6)
  capacity            Int                          @default(0)
  current_occupancy   Int                          @default(0)
  status              EvacuationCenterStatus       @default(OPEN)
  has_food_supply     Boolean                      @default(false)
  has_water_supply    Boolean                      @default(false)
  has_medical_support Boolean                      @default(false)
  has_power           Boolean                      @default(false)
  notes               String?
  created_at          DateTime                     @default(now()) @db.Timestamptz(6)
  updated_at          DateTime                     @default(now()) @updatedAt @db.Timestamptz(6)
  lgu                 Lgu                          @relation(fields: [lgu_id], references: [id], onDelete: Cascade)
  barangay            Barangay?                    @relation(fields: [barangay_id], references: [id], onDelete: SetNull)
  assignments         EvacuationCenterAssignment[]

  @@index([lgu_id])
  @@index([barangay_id])
  @@index([status])
  @@map("evacuation_centers")
}

model EvacuationCenterAssignment {
  id                   String                     @id @default(dbgenerated("concat('evac_assignment_', replace((gen_random_uuid())::text, '-'::text, ''::text))"))
  evacuation_center_id String
  family_id            String
  house_id             String
  number_of_people     Int                        @default(0)
  status               EvacuationAssignmentStatus @default(ASSIGNED)
  arrived_at           DateTime?                  @db.Timestamptz(6)
  left_at              DateTime?                  @db.Timestamptz(6)
  notes                String?
  created_at           DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at           DateTime                   @default(now()) @updatedAt @db.Timestamptz(6)
  evacuation_center    EvacuationCenter           @relation(fields: [evacuation_center_id], references: [id], onDelete: Cascade)
  family               Family                     @relation(fields: [family_id], references: [id], onDelete: Cascade)
  house                House                      @relation(fields: [house_id], references: [id], onDelete: Cascade)

  @@index([evacuation_center_id])
  @@index([family_id])
  @@index([house_id])
  @@index([status])
  @@map("evacuation_center_assignments")
}

model RescuePing {
  id                String           @id @default(dbgenerated("concat('ping_', replace((gen_random_uuid())::text, '-'::text, ''::text))"))
  phone_number      String
  latitude          Decimal          @db.Decimal(9, 6)
  longitude         Decimal          @db.Decimal(9, 6)
  accuracy_meters   Decimal?         @db.Decimal(10, 2)
  note              String?
  source            String           @default("web")
  status            RescuePingStatus @default(NEW)
  client_created_at DateTime         @db.Timestamptz(6)
  created_at        DateTime         @default(now()) @db.Timestamptz(6)
  updated_at        DateTime         @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([status])
  @@index([created_at])
  @@map("rescue_pings")
}
